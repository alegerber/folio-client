{
  "name": "folio-client",
  "version": "1.2.1",
  "description": "TypeScript client for the Folio serverless PDF API",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "docs": "typedoc",
    "prepack": "npm run build",
    "prepublishOnly": "npm run lint && npm run typecheck && npm test && npm run build"
  },
  "keywords": [
    "pdf",
    "folio",
    "serverless",
    "html-to-pdf"
  ],
  "type": "module",
  "sideEffects": false,
  "license": "MIT",
  "author": "alegerber",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alegerber/folio-client.git"
  },
  "bugs": {
    "url": "https://github.com/alegerber/folio-client/issues"
  },
  "homepage": "https://github.com/alegerber/folio-client#readme",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "tsup": "^8.0.0",
    "typedoc": "^0.28.18",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.3"
  }
}
