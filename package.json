{
  "name": "folio-client",
  "version": "2.0.0",
  "description": "TypeScript client for the Folio serverless PDF API",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "docs": "typedoc"
  },
  "keywords": [
    "pdf",
    "folio",
    "serverless",
    "html-to-pdf"
  ],
  "type": "module",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "tsup": "^8.0.0",
    "typedoc": "^0.28.18",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.3"
  }
}
